# AetherLink AI Agent Demo environment variables
# This file is only an example.
# Do not put real private keys or secret API keys in a public GitHub file.

# Future AI model API key
AI_API_KEY=your_ai_api_key_here

# Future Shelby API key
SHELBY_API_KEY=your_shelby_api_key_here

# Future Shelby S3-compatible settings
SHELBY_S3_ENDPOINT=your_shelby_s3_endpoint_here
SHELBY_S3_ACCESS_KEY=your_shelby_s3_access_key_here
SHELBY_S3_SECRET_KEY=your_shelby_s3_secret_key_here
SHELBY_S3_BUCKET=your_shelby_bucket_or_account_here

# Future Aptos testnet settings
APTOS_NETWORK=testnet
APTOS_PRIVATE_KEY=your_aptos_private_key_here
APTOS_ACCOUNT_ADDRESS=your_aptos_account_address_here
